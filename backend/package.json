    "fastify": "5.2.1",
    "prisma": "^6.15.0",
    "resend": "^6.10.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "22.14.1",
    "tsx": "4.19.3",
    "typescript": "5.8.3"
  }
