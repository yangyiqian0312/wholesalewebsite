generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DENIED
}

enum AdminPortalRole {
  admin
  sales_rep
}

enum WholesaleOrderStatus {
  SUBMITTED
  APPROVED
  PAID
  CANCELLED
}

model AdminPortalUser {
  id        String          @id @default(cuid())
  email     String          @unique
  role      AdminPortalRole
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([role, isActive])
}

model CatalogProduct {
  id                  String   @id @default(cuid())
  inflowProductId     String   @unique
  inflowEntityId      String?
  name                String
  sku                 String?
  barcode             String?
  upc                 String?
  unitPrice           Decimal? @db.Decimal(12, 2)
  marketPrice         Decimal? @db.Decimal(12, 2)
  totalQuantityOnHand Int      @default(0)
  isActive            Boolean  @default(true)
  releaseDate         String?
  rawPayload          Json
  lastSeenAt          DateTime @default(now())
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([sku])
  @@index([upc])
  @@index([barcode])
  @@index([isActive, totalQuantityOnHand])
}

model AccountApplication {
  id                        String            @id @default(cuid())
  accountNumber             String?           @unique
  publicEditToken           String?           @unique
  publicRegistrationToken   String?           @unique
  contactName               String
  email                     String
  phone                     String
  businessName              String
  businessType              String
  companyAddress            String
  city                      String
  stateProvince             String
  zipPostalCode             String
  country                   String
  website                   String?
  storeMarketplaceLink      String?
  businessModel             String
  salesChannels             String[]
  physicalStoreAddress      String?
  onlineChannelNotes        String?
  productInterests          String[]
  expectedPurchaseVolume    String
  hasResellerPermitOrTaxId  Boolean
  uploadedDocumentNames     String[]
  documents                 AccountApplicationDocument[]
  orders                    WholesaleOrder[]
  status                    ApplicationStatus @default(PENDING)
  deniedReason              String?
  reviewedByEmail           String?
  reviewedAt                DateTime?
  approvedInviteSentAt      DateTime?
  accountRegisteredAt       DateTime?
  assignedSalesRepEmail     String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([accountNumber])
  @@index([assignedSalesRepEmail, status])
}

model AccountApplicationDocument {
  id               String             @id @default(cuid())
  applicationId    String
  application      AccountApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  originalFilename String
  storedFilename   String
  mimeType         String?
  fileSizeBytes    Int
  createdAt        DateTime           @default(now())

  @@index([applicationId, createdAt])
}

model WholesaleOrder {
  id                    String             @id @default(cuid())
  applicationId         String
  application           AccountApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  customerEmail         String
  customerName          String
  businessName          String
  status                WholesaleOrderStatus @default(SUBMITTED)
  approvedByEmail       String?
  approvedAt            DateTime?
  inflowSalesOrderId    String?
  inflowOrderNumber     String?
  source                String
  subtotalAmount        Decimal            @db.Decimal(12, 2)
  totalAmount           Decimal            @default(0) @db.Decimal(12, 2)
  freightAmount         Decimal            @default(0) @db.Decimal(12, 2)
  taxName              String?
  taxRate              Decimal?           @db.Decimal(5, 2)
  taxAmount            Decimal            @default(0) @db.Decimal(12, 2)
  salesRepNote          String?
  submittedAt           DateTime           @default(now())
  lines                 WholesaleOrderLine[]
  adjustments           WholesaleOrderAdjustment[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([applicationId, submittedAt])
  @@index([customerEmail, submittedAt])
  @@index([status, submittedAt])
  @@index([submittedAt])
}

model WholesaleOrderLine {
  id             String         @id @default(cuid())
  orderId        String
  order          WholesaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  productName    String?
  productCode    String?
  submittedQuantity Int          @default(1)
  quantity       Int
  salesUomName   String?
  standardUomName String?
  salesUomStandardQuantity Decimal? 
  salesUomQuantity Decimal?
  submittedOriginalUnitPrice Decimal?
  originalUnitPrice Decimal?
  submittedDiscountPercent Decimal?
  unitPrice      Decimal        @db.Decimal(12, 2)
  discountPercent Decimal?
  submittedLineTotal Decimal    @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal        @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())

  @@index([orderId, createdAt])
  @@index([productId])
}

model WholesaleOrderAdjustment {
  id        String         @id @default(cuid())
  orderId   String
  order     WholesaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal        @db.Decimal(12, 2)
  createdAt DateTime       @default(now())

  @@index([orderId, createdAt])
}
